  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "bun --watch src/index.ts",
    "test": "echo 'no types tests'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
