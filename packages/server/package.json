{
  "name": "@wskr/server",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "wskr-server": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "bun --watch src/cli.ts",
    "start": "bun run src/cli.ts",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test test/*.unit.test.ts",
    "test:integration": "KRUN_LOG_QUIET=1 bun test test/*.integration.test.ts",
    "test:integration:real": "WSKR_USE_REAL_KRUNVM=1 bun test test/*.integration.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@wskr/types": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@wskr/client": "workspace:*"
  }
}
