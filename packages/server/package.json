{
  "name": "@wskr/server",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "wskr-server": "./src/cli.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "bun --watch src/cli.ts",
    "start": "bun run src/cli.ts",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test test/*.unit.test.ts",
    "test:integration": "KRUN_LOG_QUIET=1 bun test test/*.integration.test.ts",
    "test:integration:real": "WSKR_USE_REAL_KRUNVM=1 bun test test/*.integration.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@wskr/types": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@wskr/client": "workspace:*"
  }
}
