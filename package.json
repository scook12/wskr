{
  "name": "wskr",
  "private": true,
  "packageManager": "bun@1.2.16",
  "workspaces": [
    "packages/server",
    "packages/types",
    "packages/client",
    "packages/agent-sandbox-provider",
    "packages/opencode-plugin"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "dev": "bun run --workspaces dev",
